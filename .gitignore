# =======================================================
*.sql
*.dump
*.db
/prisma/*.db
/prisma/dev.db

# =======================================================
# 🪵 LOGS & DEBUG
# =======================================================
*.log
!gitkeep
npm-debug.log*
yarn-debug.log*
yarn-error.log*
server.log
dev.log

# =======================================================
# 💻 IDE & EDITOR
# =======================================================
.idea/
*.iml
*.swp
*.swo
*~
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
.claude
.z-ai-config

# =======================================================
# 🖥️ OS & SYSTEM FILES
# =======================================================
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# =======================================================
# 🗂️ PROJECT-SPECIFIC (Custom Paths)
# =======================================================
# Generated/artifact directories
/download/
/examples/websocket/
/mini-services/
/skills/

# Local config / temp files
local-*
tmp/
temp/
.cache/

# Build tool caches
.eslintcache
.prettierignore
.turbo/

# ⚠️ CAUTION: Only ignore root-level 'test' or 'prompt' if intentional
