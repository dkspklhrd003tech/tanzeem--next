node_modules/
.pnp/
.pnp.*
.yarn/*
!.yarn/patches/
!.yarn/plugins/
!.yarn/releases/
!.yarn/versions/
.pnpm-debug.log*

# =======================================================
# 🧪 TESTING & COVERAGE
# =======================================================
/coverage/
/test-results/
*.test.ts?(x)
*.spec.ts?(x)

# =======================================================
# ⚡ NEXT.JS + TURBOPACK
# =======================================================
/.next/
/out/
/build/
next-env.d.ts
*.tsbuildinfo
/public/
scratch/
drizzle/
# =======================================================
# 🔐 ENVIRONMENT & SECRETS
# =======================================================
.env*
.env.example
*.pem
.
# =======================================================
